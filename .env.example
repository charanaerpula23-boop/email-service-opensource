# ============================================
# Secure Email Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Your Domain
MAIL_DOMAIN=yourdomain.com
MAIL_HOST=mail.yourdomain.com
SMTP_PORT=587
IMAP_PORT=993

# SMTP Auth (your mail server credentials)
SMTP_USER=admin@yourdomain.com
SMTP_PASS=your-smtp-password

# DKIM (auto-generated on first run if not provided)
DKIM_SELECTOR=mail
DKIM_PRIVATE_KEY_PATH=./dkim-private.pem

# Database
DB_PATH=./data/email.db

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
